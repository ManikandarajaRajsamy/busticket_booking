# Environment variables for RedBus clone backend

# Database Configuration
DATABASE_URL=sqlite:///redbus.db
# Production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# Supabase example:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES_HOURS=12

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# CORS Configuration
CORS_ENABLED=True
# Comma-separated list for deployed frontend origins
# CORS_ORIGINS=https://your-project.vercel.app,https://your-custom-domain.com
